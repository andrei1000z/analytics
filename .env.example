# EuroAnalytics — dashboard env
# Copy to .env.local and fill in. Never commit .env.local.
# Set the same values in Vercel project settings (Production + Preview).

# Public, browser-safe values — must be prefixed with NEXT_PUBLIC_ to be
# exposed to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only values — used in Route Handlers / Server Actions.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth — basic password gate. ADMIN_PASSWORD is what the user types in the
# /login form; AUTH_SECRET is the cookie value set when login succeeds. Both
# must be set for the dashboard to be reachable.
ADMIN_PASSWORD=
AUTH_SECRET=
