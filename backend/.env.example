# EuroAnalytics — backend env
# Copy to .env and fill in. Never commit .env.

# Supabase project URL, e.g. https://abcdefghijkl.supabase.co
SUPABASE_URL=

# Supabase anon (public) key — used by the tracker / write path.
# For server-side reads, swap this for SUPABASE_SERVICE_ROLE_KEY in production.
SUPABASE_ANON_KEY=

# Optional — overrides the default port (4000)
PORT=4000
