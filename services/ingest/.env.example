# Copy to .env beside docker-compose.yml on the host.
# Both vars are MANDATORY — compose refuses to start without them.

# The public hostname Caddy will request a Let's Encrypt cert for.
DOMAIN=ingest.example.eu

# Random secret feeding the daily IP-hash salt KDF. Generate with:
#   openssl rand -hex 32
# Rotating this rotates yesterday's IP-hash linkability into nothing.
INGEST_SECRET=replace-with-32-bytes-of-hex
