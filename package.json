{
  "name": "analytics",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first, EU-sovereign, zero-knowledge web analytics. Liquid Glass 2026.",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @analytics/dashboard dev",
    "build": "pnpm --filter @analytics/dashboard build",
    "build:tracker": "pnpm --filter @analytics/tracker build",
    "build:all": "pnpm -r --if-present run build",
    "preview": "pnpm --filter @analytics/dashboard preview",
    "typecheck": "pnpm -r --if-present run typecheck",
    "gen:icon": "pnpm --filter @analytics/dashboard gen:icon"
  }
}
